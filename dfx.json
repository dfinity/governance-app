{
  "canisters": {
    "governance-app-backend": {
      "type": "custom",
      "candid": "src/governance-app-backend/backend.did",
      "wasm": "target/wasm32-unknown-unknown/release/governance_app_backend.wasm",
      "gzip": true,
      "optimize": "cycles",
      "build": [
        "./scripts/config.sh -n local",
        "npm run build",
        "cargo build --target wasm32-unknown-unknown --release -p governance-app-backend --locked --features testnet"
      ],
      "metadata": [
        {
          "name": "candid:service"
        }
      ]
    }
  },
  "networks": {
    "local": {
      "type": "ephemeral",
      "bind": "127.0.0.1:8080"
    }
  },
  "defaults": {
    "build": {
      "args": "",
      "packtool": ""
    }
  },
  "output_env_file": ".env",
  "version": 1
}
