{
  "name": "governance-app-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup": "npm i && dfx canister create governance-app-backend && dfx generate governance-app-backend && dfx deploy",
    "start": "vite",
    "prebuild": "dfx generate",
    "generate:known-neurons": "node scripts/convert-known-neurons.ts && npm run format:fix",
    "build": "tsc && vite build",
    "format": "prettier --check .",
    "format:fix": "prettier --write 'src/**/*.{json,js,jsx,ts,tsx,css,scss}' 'eslint.config.js'",
    "lint": "eslint . --ext ts,tsx,css --report-unused-disable-directives --max-warnings 0",
    "check:i18n": "node scripts/check-unused-translations.ts",
    "lint:fix": "eslint . --ext ts,tsx,css --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "IGNORE_SCREENSHOTS=1 playwright test --headed --project=chromium",
    "update-snapshots": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@dfinity/utils": "4.1.0",
    "@icp-sdk/auth": "5.0.0",
    "@icp-sdk/canisters": "3.5.0",
    "@icp-sdk/core": "5.0.0",
    "@plausible-analytics/tracker": "0.4.4",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "@tanstack/react-router": "1.159.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "i18next": "25.8.7",
    "ic-use-internet-identity": "0.7.0",
    "lockfile-lint": "5.0.0",
    "lucide-react": "0.564.0",
    "motion": "12.34.0",
    "qrcode.react": "4.2.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-aria-components": "1.15.1",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.4",
    "react-markdown": "10.1.0",
    "recharts": "3.7.0",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.4.0",
    "tailwindcss": "4.1.18",
    "tailwindcss-animate": "1.0.7",
    "tailwindcss-react-aria-components": "2.0.1",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@eslint/css": "0.14.1",
    "@playwright/test": "1.58.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.1.18",
    "@tanstack/eslint-plugin-query": "5.91.4",
    "@tanstack/react-router-devtools": "1.159.5",
    "@tanstack/router-plugin": "1.159.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "dotenv": "17.3.1",
    "eslint": "10.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "jsdom": "28.0.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "rollup-plugin-visualizer": "6.0.5",
    "tailwind-csstree": "0.1.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vite": "7.3.1",
    "vite-plugin-environment": "1.1.3",
    "vitest": "4.0.18"
  }
}
