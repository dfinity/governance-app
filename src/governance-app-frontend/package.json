{
  "name": "governance-app-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup": "npm i && dfx canister create governance-app-backend && dfx generate governance-app-backend && dfx deploy",
    "start": "vite --port 3000",
    "prebuild": "dfx generate",
    "build": "tsc && vite build",
    "format": "prettier --write 'src/**/*.{json,js,jsx,ts,tsx,css,scss}'",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix"
  },
  "dependencies": {
    "@dfinity/agent": "^3.2.0",
    "@dfinity/candid": "^3.2.0",
    "@dfinity/ledger-icp": "^5.0.0-next-2025-08-14",
    "@dfinity/nns": "^10.0.0-next-2025-08-14",
    "@dfinity/principal": "^3.2.0",
    "@dfinity/utils": "^3.0.0-next-2025-08-14",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.85.0",
    "classnames": "^2.5.1",
    "ic-use-internet-identity": "^0.4.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.83.1",
    "@types/node": "^24.2.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "babel-plugin-react-compiler": "^19.1.0-rc.2",
    "dotenv": "^17.2.1",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^6.0.0-rc.1",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-plugin-environment": "^1.1.3"
  }
}
