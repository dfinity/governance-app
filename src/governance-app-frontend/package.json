{
  "name": "governance-app-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup": "npm i && dfx canister create governance-app-backend && dfx generate governance-app-backend && dfx deploy",
    "start": "vite --port 3000",
    "prebuild": "dfx generate",
    "build": "tsc && vite build",
    "format": "prettier --check .",
    "format:fix": "prettier --write 'src/**/*.{json,js,jsx,ts,tsx,css,scss}' 'eslint.config.js'",
    "lint": "eslint . --ext ts,tsx,css --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx,css --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "IGNORE_SCREENSHOTS=1 playwright test --headed --project=chromium",
    "update-snapshots": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@dfinity/agent": "^3.2.0",
    "@dfinity/candid": "^3.2.0",
    "@dfinity/ledger-icp": "^6.0.0",
    "@dfinity/nns": "^10.0.1",
    "@dfinity/principal": "^3.2.0",
    "@dfinity/utils": "^3.0.1",
    "@tanstack/react-query": "^5.85.0",
    "@tanstack/react-router": "^1.131.27",
    "@untitledui/icons": "^0.0.19",
    "classnames": "^2.5.1",
    "i18next": "^25.4.0",
    "ic-use-internet-identity": "^0.5.0",
    "react": "^19.1.1",
    "react-aria-components": "^1.12.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^15.7.1",
    "react-loading-skeleton": "^3.5.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.0.1"
  },
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/eslint-plugin-query": "^5.83.1",
    "@tanstack/react-router-devtools": "^1.131.27",
    "@tanstack/router-plugin": "^1.131.27",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.2.1",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "babel-plugin-react-compiler": "^19.1.0-rc.2",
    "dotenv": "^17.2.1",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^6.0.0-rc.1",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.5",
    "vite-plugin-environment": "^1.1.3",
    "vitest": "^3.2.4"
  }
}
