{
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "name": "the-governance-app",
  "scripts": {
    "prebuild": "npm run prebuild --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "format": "npm run format --workspaces --if-present && cargo fmt --check",
    "lint": "npm run lint --workspaces --if-present",
    "lint:lockfile": "lockfile-lint",
    "check:i18n": "npm run check:i18n --workspaces --if-present",
    "start": "npm start --workspaces --if-present",
    "start:ic": "./scripts/start-pocket-ic.sh",
    "start:local": "./scripts/config.sh -n local && npm run start",
    "start:mainnet": "./scripts/config.sh -n ic && npm run start",
    "test": "npm test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "update-snapshots": "npm run update-snapshots --workspaces --if-present"
  },
  "type": "module",
  "workspaces": [
    "src/governance-app-frontend"
  ]
}
