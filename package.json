{
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "name": "test-nns",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --write . && cargo fmt",
    "format:check": "prettier --check . && cargo fmt --check",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:check": "npm run lint --workspaces --if-present",
    "prebuild": "npm run prebuild --workspaces --if-present",
    "pretest": "npm run prebuild --workspaces --if-present",
    "start": "npm run i18n && npm start --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "i18n": "npm run i18n-merge && npm run i18n-toc && npm run i18n-interface && prettier --write src/governance-app-frontend/src/i18n/generated-* --ignore-path",
    "i18n-merge": "mkdir -p ./src/governance-app-frontend/src/i18n/generated && i18next-resources-for-ts merge -i ./src/governance-app-frontend/src/i18n/en -o ./src/governance-app-frontend/src/i18n/generated/en.json && i18next-resources-for-ts merge -i ./src/governance-app-frontend/src/i18n/de -o ./src/governance-app-frontend/src/i18n/generated/de.json",
    "i18n-toc": "i18next-resources-for-ts toc -i ./src/governance-app-frontend/src/i18n/generated -o ./src/governance-app-frontend/src/i18n/generated-toc.ts",
    "i18n-interface": "i18next-resources-for-ts interface -i src/governance-app-frontend/src/i18n/en -o ./src/governance-app-frontend/src/i18n/generated-i18n-resources.d.ts"
  },
  "type": "module",
  "workspaces": [
    "src/governance-app-frontend"
  ],
  "dependencies": {
    "i18next": "^25.3.6",
    "react-i18next": "^15.6.1"
  },
  "devDependencies": {
    "i18next-resources-for-ts": "^1.6.0"
  }
}
